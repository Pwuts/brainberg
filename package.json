{
  "name": "brainberg",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "class-variance-authority": "^0.7",
    "clsx": "^2.1",
    "date-fns": "^4.1",
    "drizzle-orm": "^0.39",
    "fast-xml-parser": "^5.6.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.470",
    "next": "16.2.4",
    "node-html-parser": "^7.1.0",
    "postgres": "^3.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "slugify": "^1.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6",
    "turndown": "^7.2.4",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/turndown": "^5.0.6",
    "drizzle-kit": "^0.30",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.19",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.27.0",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml,html}": [
      "prettier --write"
    ]
  }
}
