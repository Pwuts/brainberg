# Database
# Dev: DATABASE_URL - used by `pnpm dev` to connect to dev DB (see docker-compose.dev.yml)
DATABASE_URL="postgresql://brainberg:devpassword@localhost:5432/brainberg_dev"
# Prod: DB_PASSWORD - used in docker-compose.yml
# DB_PASSWORD=CHANGE_ME

# Auth.js v5
AUTH_SECRET=""                    # openssl rand -hex 32
AUTH_URL="http://localhost:3000"  # Prod: https://your-domain
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Scraping / Admin
CRON_SECRET=""
ADMIN_SECRET=""                  # For admin API + UI authentication
EVENTBRITE_API_TOKEN=""
ANTHROPIC_API_KEY=""             # Optional — enables AI moderation of scraped events

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"   # Prod: https://your-domain
NEXT_PUBLIC_APP_NAME="Brainberg.eu"

# Analytics — leave unset to disable (forks should not inherit upstream analytics).
# Set to the full Plausible script URL, e.g. https://plausible.io/js/pa-XXXXXXXX.js
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=""

# Dev only — comma-separated LAN hosts allowed to load Next dev resources
# (e.g. testing on a phone). Leave unset in production.
# NEXT_DEV_ORIGINS="192.168.x.x,my-laptop.local"
